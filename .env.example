# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765

# Whisper transcription
WHISPER_MODEL_NAME=base
WHISPER_MODEL_DIR=./models/whisper

# Ollama LLM
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# Inference device: cpu | cuda | mps
DEVICE=cpu

# Audio capture (microphone pipeline)
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_DURATION_S=30
AUDIO_CHUNK_OVERLAP_S=5
VAD_ENABLED=false
VAD_THRESHOLD=0.5
FFMPEG_PATH=ffmpeg
AUDIO_CHUNK_QUEUE_MAXSIZE=32
# Comma-separated allowed roots for POST /api/capture/start/file (default: user home)
AUDIO_FILE_ROOTS=

# Set true to run model setup automatically on first app launch
RUN_MODEL_SETUP_ON_START=false

# Set true to open DevTools when running npm run dev
OPEN_DEVTOOLS=false
