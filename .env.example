# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765

# Whisper transcription
WHISPER_MODEL_NAME=base
WHISPER_MODEL_DIR=./models/whisper

# Ollama LLM
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# Inference device: cpu | cuda | mps
DEVICE=cpu

# Set true to run model setup automatically on first app launch
RUN_MODEL_SETUP_ON_START=false

# Set true to open DevTools when running npm run dev
OPEN_DEVTOOLS=false
